<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Paksa HTTPS (Opsional - Hapus jika belum ada SSL)
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2. Redirect ke folder public
    RewriteRule ^(.*)$ public/$1 [L]

    # 3. Blokir akses ke file sensitif
    RewriteRule ^(\.env|\.git|composer\.json|composer\.lock|package\.json|package-lock\.json)$ - [F,L]
</IfModule>